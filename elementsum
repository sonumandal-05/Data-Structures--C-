#include<stdio.h>

int main()
{
    int arr[3][3], i, j, sum=0;

    printf("Enter elements of 3x3 matrix:\n");

    for(i=0;i<3;i++)
    {
        for(j=0;j<3;j++)
        {
            scanf("%d",&arr[i][j]);
        }
    }

    printf("Diagonal elements are:\n");

    for(i=0;i<3;i++)
    {
        for(j=0;j<3;j++)
        {
            if(i==j)
            {
                printf("%d ",arr[i][j]);
                sum = sum + arr[i][j];
            }
        }
    }

    printf("\nSum of diagonal elements = %d",sum);

    return 0;
}